{
  "name": "expenova-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "Clitus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Clituschris/expenova-client.git"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "codegen:pull-spec": "node scripts/pull-spec.mjs",
    "codegen": "npm run codegen:pull-spec && openapi-typescript ./openapi.json -o ./src/api/schema.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.16.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "js-cookie": "^3.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.4",
    "typescript-eslint": "^8.59.2",
    "vercel": "^54.0.0",
    "vite": "^8.0.12"
  }
}
